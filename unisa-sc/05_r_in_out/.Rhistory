## funzione logit
p <- seq(0.001, 0.999, length = 1000)
y <- log(p/{1-p})
plot(p, y, t="l" , xlab = "p" , ylab = "logit(p)" , lwd = 2)
grid()
abline(h = 0)
abline(v = 0.5)
pp <- 1/{1+exp(-y)}
plot(y, pp, t="l" , xlab = "logit(p)" , ylab = "p" , lwd = 2)
grid()
abline(h=0.5)
abline(v = 0)
## logit :: calcola il logit o la logistica in x
##
## * se inverse=FALSE calcola logit(x)
## * se inverse=TRUE  calcola logistic(x)
## * nel caso di logit(x) tronca le probabilità nell'intervallo
##   [tol , 1-tol]
logit <-  function(x , inverse = FALSE , tol = .Machine$double.eps){
if(inverse){
y <- 1 / { 1 + exp(-x) }
}else{
if(any(x<0) | any(x>1)){
stop("x must be a probability, that is x in (0,1)")
}
x[x < tol]      <- tol
x[x > {1-tol}]  <- 1-tol
y  <- log(x) - log(1-x)
}
return(y)
}
## proviamo i casi problematici
p <- c(0 , 1)
log(p/{1-p})
p <- c(0.5, 0 , 1 , -0.001, 1.001)
logit(p)
p <- c(0.5, 0 , 1)
logit(p)
logit <-  function(x , inverse = FALSE , tol = .Machine$double.eps){
if(inverse){
y <- 1 / { 1 + exp(-x) }
}else{
if(any(x<0) | any(x>1)){
stop("x must be a probability, that is x in (0,1)")
}
x[x < tol]      <- tol
x[x > {1-tol}]  <- 1-tol
y  <- log(x) - log(1-x)
}
return(y)
}
## Dataset: 'baby.dat'  (https://stat.ethz.ch/Teaching/Datasets/)
##
dat <-  read.table("baby.dat",header=TRUE)
str(dat)
## pairs plot
pairs(dat)
## pairs plot condizionatamente alle due classi
cl    <- as.factor(dat$Survival)
ucol  <- c("red", "blue")[unclass(cl)]
pairs(dat, col = ucol)
str(dat)
fit <- glm(dat$Survival ~ 1 + dat$Weight + dat$Age
+ dat$X1.Apgar + dat$X5.Apgar + dat$pH ,
family= "binomial")
## oppure brevemente
fit <- glm(Survival ~ . , data = dat, family = "binomial")
str(fit)
summary(fit)
## estrazione del vettore b stimato
coef(summary(fit))
b <- coef(summary(fit))[,1]
b
## generazione di un campione iid  {U_1, U_2, ..., U_n} da una distribuzione
## uniforme(0,1)
n <- 5
u <- runif(n=n, min = 0, max = 1)
u
u <- runif(n=n, min = 0, max = 1)
u
u <- runif(n=n, min = 0, max = 1)
u
## il seed fissa il punto iniziale e permette di riprodurre la stessa catena
## causuale
set.seed(4102021)
u <- runif(n=n, min = 0, max = 1)
u
u <- runif(n=5000, min = 0, max = 1)
u
hist(u)
u <- runif(n=10000, min = 0, max = 1)
u
hist(u)
## sample size
n <- 10
## il seed fissa il punto iniziale e permette di riprodurre la stessa catena
## causuale
set.seed(4102021)
u <- runif(n=5, min = 0, max = 1)
u
u <- runif(n=5, min = 0, max = 1)
u
u <- runif(n=5, min = 0, max = 1)
u
## sample size
n <- 10
u <- runif(n=n)
u
## step 2: calcoliamo l'inversa dalla CDF di una esponenziale sul campione
## uniforme
lambda <- 10
lambda <- 10
x <- -1/lambda * log(1-u)
x
## ora X ~ Esponenziale(lambda)
hist(x)
## ripetiamo la generazione fissando un n più grande
set.seed(2568952)
n <- 1000
u <- runif(n=n)
x <- -1/lambda * log(1-u)
