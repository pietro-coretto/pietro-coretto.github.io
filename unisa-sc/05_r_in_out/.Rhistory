## Regressione multinomial logit
## *****************************
library(nnet)
## "High School and Beyond" data set
## https://nces.ed.gov/surveys/hsb/
## Campione di 200 studenti. La risposta è 'prog', ovvero il programma di studi
## dell i-mo studente. I predittori sono variabili che descrivono lo stato
## economico e sociale, ed altre variabili di performance scolastica
load("hsb.RData")
str(dat)
## prevalenza
n <- nrow(dat)
table(dat$prog) / n * 100
## fissiamo la baseline class
dat$y <- relevel(dat$prog, ref = "academic")
dat$y
## stima del modello multinomial logit
fit <- multinom( y ~ 1 + female + ses + write + math , data = dat)
summary(fit)
## stima delle posterior class  probabilities
hat_eta  <- predict(fit, type="probs")
head(hat_eta)
## classificatore Bayesiano
hat_y <- apply(hat_eta , 1, which.max)
hat_y
## per associare i labels della y
levels(dat$y)[hat_y]
hat_y <- factor( levels(dat$y)[hat_y]  , ordered = FALSE)
hat_y
## matrice di confusione
table(ClassiPreviste = hat_y, ClassiOsservate = dat$y)
## training error rate (misura soggetta a distorsione!)
mean(hat_y != dat$y)
## accuratezza sul training set (misura soggetta a distorsione!)
1-mean(hat_y != dat$y)
## dobbiamo generare 3 dummy
dat$y1 <- ifelse(dat$y == "academic", 1 , 0)
dat$y2 <- ifelse(dat$y == "general",  1 , 0)
dat$y3 <- ifelse(dat$y == "vocation", 1 , 0)
## stima dei tre logit
fit1 <- glm(dat$y1 ~ 1 + female + ses + write + math ,
data = dat , family= "binomial")
fit2 <- glm(dat$y2 ~ 1 + female + ses + write + math ,
data = dat , family= "binomial")
fit3 <- glm(dat$y3 ~ 1 + female + ses + write + math ,
data = dat , family= "binomial")
## stima delle posterior class  probability
eta1  <- predict(fit1, type="response")
eta2  <- predict(fit2, type="response")
eta3  <- predict(fit3, type="response")
## normalizziamo le probabilità (non necessario)
hat_eta_2 <- cbind(accademic = eta1 , general = eta2 , vocation = eta3)
head(hat_eta_2)
faux <- function(x){x/sum(x)}
u <- t(apply(hat_eta_2, 1, FUN = faux))
u
## classificatore bayesiano
hat_y_2 <- apply(hat_eta_2 , 1, which.max)
hat_y_2 <- factor( levels(dat$y)[hat_y_2] )
hat_y_2
## matrice di confusione
table(ClassePrevista = hat_y_2, ClasseVera = dat$y)
## matrice di confusione
table(ClassePrevista = hat_y_1, ClasseVera = dat$y)
## matrice di confusione
table(ClassePrevista = hat_y, ClasseVera = dat$y)
## training error rate
mean(hat_y_2  != dat$y)
## matrice di confusione tra i due classificatori
table(hat_y , hat_y_2)
