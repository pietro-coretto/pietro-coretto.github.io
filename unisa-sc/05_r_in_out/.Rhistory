main = "errore di approssimazione",
xlab = "n",
ylab = "errore (assoluto)")
abline(h = 0, lwd = 2, col = 4)
## Consideriamo X ~ ChiQuadro(df = 5)
set.seed(32569)
n <- 100
x <- rchisq(n=n , df = 5)
ecdf_X <- ecdf(x)
str(ecdf_X)
Fn <- ecdf_X(x)
Fn
plot(ecdf(x))
## confrontiamo la ECDF con la CDF vera
x  <- sort(x)
Fn <- ecdf_X(x)
x  <- sort(x)
Fn <- ecdf_X(x)
Fvera <- pchisq(x, df = 5)
plot(x, Fvera, t='l', col=2, lwd = 2)
lines(x, Fn, col=4, lwd = 2)
## ... rifacciamo l'esempio nell'asintotico
set.seed(32569)
n     <- 1e+3
x     <- sort( rchisq(n=n , df = 5) )
Fn    <- ecdf(x)(x)
Fvera <- pchisq(x, df = 5)
plot(x, Fvera, t='l', col=2, lwd = 2)
lines(x, Fn, col=4, lwd = 2)
## errore di approssimazione (pointwise)
err <- abs(Fn - Fvera)
plot(x, err, t='l', col =2, lwd = 2)
## ... rifacciamo l'esempio nell'asintotico
set.seed(32569)
n     <- 1e+6
x     <- sort( rchisq(n=n , df = 5) )
Fn    <- ecdf(x)(x)
Fvera <- pchisq(x, df = 5)
plot(x, Fvera, t='l', col=2, lwd = 2)
lines(x, Fn, col=4, lwd = 2)
n     <- 1e+5
x     <- sort( rchisq(n=n , df = 5) )
Fn    <- ecdf(x)(x)
Fvera <- pchisq(x, df = 5)
plot(x, Fvera, t='l', col=2, lwd = 2)
lines(x, Fn, col=4, lwd = 2)
## errore di approssimazione (pointwise)
err <- abs(Fn - Fvera)
plot(x, err, t='l', col =2, lwd = 2)
