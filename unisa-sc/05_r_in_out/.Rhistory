## in R ci sono funzioni che generano numeri casuali da varie distribuzioni
## la maggior parte degli algoritmi si basano generalmente sull'IST
##
n <- 10
rnorm(n=n, mean = 0, sd = 1)   ## normale
rt(n=n, df = 3)                ## Student-t a media 0
rchisq(n=n, df =3)             ## Chi quadratro
## generiamo un campione iid da una Student-t e vediamo se funziona
set.seed(235986)
n <- 100
x <- rt(n=n, df = 10)
## media aritmetica dei risultati (sample mean, o empirical mean)
mu_n <- mean(x)
mu_n
## errore di approssimazione |mu_n - mu|
mu <- 0
abs(mu_n - mu)
set.seed(235986)
n <- 1e+3
x <- rt(n=n, df = 15)
mu_n <- mean(x)
abs(mu_n - mu)
## proviamo a vedere cosa accade quando n cresce
set.seed(1234)
N          <- c(50, 100, 250, 500, 1000, 2500, 5e+4, 1e+5, 1e+6)
approx_err <- rep(0, length = length(N))
set.seed(1234)
N          <- c(50, 100, 250, 500, 1000, 2500, 5e+4, 1e+5, 1e+6)
approx_err <- rep(0, length = length(N))
for (i in 1:length(N)) {
x <- rt(n=N[i], df = 15)
approx_err[i] <- abs(mean(x) - mu)
}
plot(N, approx_err, t='b', col = 2, lwd = 2,
main = "errore di approssimazione",
xlab = "n",
ylab = "errore (assoluto)")
abline(h = 0, lwd = 2, col = 4)
## proviamo a vedere cosa accade quando n cresce
